#!name=植物大战僵尸2 iOS 存档修改
#!desc=拦截并重定向 PVZ2 存档请求，实现特定存档数据的本地劫持与下发。
#!category=Game Hack

[MITM]
hostname = %APPEND% cloudpvz2ios.ditwan.cn

[Script]
# 拦截存档请求，requires-body=1 确保能读取到请求体
PVZ2_Archive_Mock = type=http-request, pattern=^http://cloudpvz2ios\.ditwan\.cn, requires-body=1, max-size=0, script-path=https://raw.githubusercontent.com/xiaozei0707/proxy/refs/heads/main/loon/lpx/zwdzjs/11.js
