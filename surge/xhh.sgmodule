#!name=Xiaoheihe Sign
#!desc=Capture Xiaoheihe credentials and run daily sign-in.

[MITM]
hostname = %APPEND% api.xiaoheihe.cn

[Script]
Xiaoheihe Capture = type=http-request, pattern=^https:\/\/api\.xiaoheihe\.cn\/(?:account\/info|task\/sign_v3\/get_sign_state|task\/sign_v3\/sign|task\/sign_list|task\/list_v2), script-path=https://raw.githubusercontent.com/xiaozei0707/proxy/refs/heads/main/surge/xhh.js, requires-body=false, timeout=30
Xiaoheihe Sign = type=cron, cronexp="15 8 * * *", script-path=https://raw.githubusercontent.com/xiaozei0707/proxy/refs/heads/main/surge/xhh.js, timeout=60
