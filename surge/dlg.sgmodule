#!name=多邻国 X
#!desc=对 多邻国 深度学习探索;
#!openUrl=https://apps.apple.com/app/id570060128
#!author=j4gm4g[https://j4gm4g.github.io]
#!icon=https://is1-ssl.mzstatic.com/image/thumb/Purple211/v4/df/0c/5f/df0c5f65-4c7c-8680-79f3-510ba742364a/AppIcon-0-0-1x_U007epad-0-1-85-220.png/460x0w.webp
#!date=2025-10-00 00:00:00

[MITM]
hostname = %APPEND% ios-api-*.duolingo.*, api*.duolingo.*

[Script]
订购等级 = type=http-response, pattern=^https?:\/\/(?:ios-api-[^.]+|api[^.]+)\.duolingo\.[a-z.]+\/.*\/users\/.*\?fields=subscriberLevel, requires-body=true, script-path=https://raw.githubusercontent.com/xiaozei0707/proxy/main/surge/dlg_config/level.js, timeout=60
订购配置 = type=http-response, pattern=^https?:\/\/(?:ios-api-[^.]+|api[^.]+)\.duolingo\.[a-z.]+\/.*\/users\/.*\/available-features.*$, requires-body=true, script-path=https://raw.githubusercontent.com/xiaozei0707/proxy/main/surge/dlg_config/features.js, timeout=60
订购信息 = type=http-response, pattern=^https?:\/\/(?:ios-api-[^.]+|api[^.]+)\.duolingo\.[a-z.]+\/\d{4}-\d{1,2}-\d{1,2}\/batch, requires-body=true, script-path=https://raw.githubusercontent.com/xiaozei0707/proxy/main/surge/dlg_config/batch.js, timeout=60
